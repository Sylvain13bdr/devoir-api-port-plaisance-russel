<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Modifier réservation - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/api-docs">Documentation API</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Modifier la réservation</h1>
    <div class="card">
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <form action="/catways/<%= catwayId %>/reservations/<%= reservation._id %>/update" method="POST">
        <div class="form-group">
          <label>Nom du client</label>
          <input type="text" name="clientName" value="<%= reservation.clientName %>" required>
        </div>
        <div class="form-group">
          <label>Nom du bateau</label>
          <input type="text" name="boatName" value="<%= reservation.boatName %>" required>
        </div>
        <div class="form-group">
          <label>Date de début</label>
          <input type="date" name="startDate" value="<%= new Date(reservation.startDate).toISOString().split('T')[0] %>" required>
        </div>
        <div class="form-group">
          <label>Date de fin</label>
          <input type="date" name="endDate" value="<%= new Date(reservation.endDate).toISOString().split('T')[0] %>" required>
        </div>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/catways/<%= catwayId %>/reservations" class="btn btn-secondary">Annuler</a>
      </form>
    </div>
  </div>
</body>
</html>
