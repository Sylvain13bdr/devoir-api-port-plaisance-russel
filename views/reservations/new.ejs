<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Nouvelle réservation - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/api-docs">Documentation API</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Nouvelle réservation — Catway n° <%= catwayId %></h1>
    <div class="card">
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <form action="/catways/<%= catwayId %>/reservations" method="POST">
        <div class="form-group">
          <label>Nom du client</label>
          <input type="text" name="clientName" required>
        </div>
        <div class="form-group">
          <label>Nom du bateau</label>
          <input type="text" name="boatName" required>
        </div>
        <div class="form-group">
          <label>Date de début</label>
          <input type="date" name="startDate" required>
        </div>
        <div class="form-group">
          <label>Date de fin</label>
          <input type="date" name="endDate" required>
        </div>
        <button type="submit" class="btn btn-primary">Créer</button>
        <a href="/catways/<%= catwayId %>/reservations" class="btn btn-secondary">Annuler</a>
      </form>
    </div>
  </div>
</body>
</html>
