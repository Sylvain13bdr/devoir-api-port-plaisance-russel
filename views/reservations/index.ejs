<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Réservations - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/api-docs">Documentation API</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Réservations — Catway n° <%= catwayId %></h1>
    <a href="/catways/<%= catwayId %>/reservations/new" class="btn btn-primary" style="margin-bottom:16px">+ Nouvelle réservation</a>
    <a href="/catways" class="btn btn-secondary" style="margin-bottom:16px">Retour aux catways</a>
    <% if (reservations.length === 0) { %>
      <p>Aucune réservation pour ce catway.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Client</th>
            <th>Bateau</th>
            <th>Début</th>
            <th>Fin</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(r => { %>
            <tr>
              <td><%= r.clientName %></td>
              <td><%= r.boatName %></td>
              <td><%= new Date(r.startDate).toLocaleDateString('fr-FR') %></td>
              <td><%= new Date(r.endDate).toLocaleDateString('fr-FR') %></td>
              <td>
                <a href="/catways/<%= catwayId %>/reservations/<%= r._id %>" class="btn btn-secondary">Détail</a>
                <a href="/catways/<%= catwayId %>/reservations/<%= r._id %>/edit" class="btn btn-primary">Modifier</a>
                <form action="/catways/<%= catwayId %>/reservations/<%= r._id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Supprimer cette réservation ?')">
                  <button type="submit" class="btn btn-danger">Supprimer</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
