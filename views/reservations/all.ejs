<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Réservations - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/api-docs">Documentation API</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Réservations par catway</h1>
    <p style="margin-bottom:16px">Sélectionnez un catway pour gérer ses réservations :</p>
    <table>
      <thead>
        <tr>
          <th>N°</th>
          <th>Type</th>
          <th>État</th>
          <th>Réservations</th>
        </tr>
      </thead>
      <tbody>
        <% catways.forEach(c => { %>
          <tr>
            <td><%= c.catwayNumber %></td>
            <td><%= c.catwayType %></td>
            <td><%= c.catwayState %></td>
            <td>
              <a href="/catways/<%= c.catwayNumber %>/reservations" class="btn btn-primary">Voir / Gérer</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
