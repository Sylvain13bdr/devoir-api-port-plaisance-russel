<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Documentation API - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .endpoint { background:#f0f4f8; border-left:4px solid #1a3c5e; padding:10px 16px; margin-bottom:8px; border-radius:0 4px 4px 0; }
    .method { display:inline-block; padding:2px 10px; border-radius:4px; font-size:0.8rem; font-weight:bold; margin-right:10px; }
    .get { background:#27ae60; color:#fff; }
    .post { background:#2980b9; color:#fff; }
    .put { background:#e67e22; color:#fff; }
    .delete { background:#c0392b; color:#fff; }
    code { background:#e8ecef; padding:2px 6px; border-radius:3px; font-size:0.9rem; }
    section { margin-bottom:32px; }
  </style>
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/">Accueil</a>
    </div>
  </nav>
  <div class="container">
    <h1>Documentation de l'API</h1>
    <p style="margin-bottom:24px; color:#555;">API privée de gestion des catways et réservations du Port de Plaisance Russell.</p>

    <section>
      <h2>Authentification</h2>
      <div class="endpoint">
        <span class="method post">POST</span><code>/login</code>
        <p>Connexion. Corps : <code>{ email, password }</code></p>
      </div>
      <div class="endpoint">
        <span class="method get">GET</span><code>/logout</code>
        <p>Déconnexion. Redirige vers la page d'accueil.</p>
      </div>
    </section>

    <section>
      <h2>Catways</h2>
      <div class="endpoint">
        <span class="method get">GET</span><code>/catways</code>
        <p>Retourne la liste de tous les catways.</p>
      </div>
      <div class="endpoint">
        <span class="method get">GET</span><code>/catways/:id</code>
        <p>Retourne le détail d'un catway. <code>id</code> = numéro du catway.</p>
      </div>
      <div class="endpoint">
        <span class="method post">POST</span><code>/catways</code>
        <p>Crée un catway. Corps : <code>{ catwayNumber, catwayType, catwayState }</code></p>
      </div>
      <div class="endpoint">
        <span class="method put">PUT</span><code>/catways/:id</code>
        <p>Modifie l'état d'un catway (seul <code>catwayState</code> est modifiable). Corps : <code>{ catwayState }</code></p>
      </div>
      <div class="endpoint">
        <span class="method delete">DELETE</span><code>/catways/:id</code>
        <p>Supprime un catway.</p>
      </div>
    </section>

    <section>
      <h2>Réservations</h2>
      <p style="margin-bottom:8px; font-size:0.9rem; color:#555;">Les réservations sont une sous-ressource des catways.</p>
      <div class="endpoint">
        <span class="method get">GET</span><code>/catways/:id/reservations</code>
        <p>Liste toutes les réservations d'un catway.</p>
      </div>
      <div class="endpoint">
        <span class="method get">GET</span><code>/catways/:id/reservations/:idReservation</code>
        <p>Retourne le détail d'une réservation.</p>
      </div>
      <div class="endpoint">
        <span class="method post">POST</span><code>/catways/:id/reservations</code>
        <p>Crée une réservation. Corps : <code>{ clientName, boatName, startDate, endDate }</code></p>
      </div>
      <div class="endpoint">
        <span class="method put">PUT</span><code>/catways/:id/reservations</code>
        <p>Modifie une réservation. Corps : <code>{ clientName, boatName, startDate, endDate }</code></p>
      </div>
      <div class="endpoint">
        <span class="method delete">DELETE</span><code>/catways/:id/reservations/:idReservation</code>
        <p>Supprime une réservation.</p>
      </div>
    </section>

    <section>
      <h2>Utilisateurs</h2>
      <div class="endpoint">
        <span class="method get">GET</span><code>/users/</code>
        <p>Liste tous les utilisateurs.</p>
      </div>
      <div class="endpoint">
        <span class="method get">GET</span><code>/users/:email</code>
        <p>Retourne le détail d'un utilisateur.</p>
      </div>
      <div class="endpoint">
        <span class="method post">POST</span><code>/users/</code>
        <p>Crée un utilisateur. Corps : <code>{ username, email, password }</code></p>
      </div>
      <div class="endpoint">
        <span class="method put">PUT</span><code>/users/:email</code>
        <p>Modifie un utilisateur. Corps : <code>{ username, email, password }</code></p>
      </div>
      <div class="endpoint">
        <span class="method delete">DELETE</span><code>/users/:email</code>
        <p>Supprime un utilisateur.</p>
      </div>
    </section>

    <section>
      <h2>Modèles de données</h2>
      <div class="card">
        <h3 style="margin-bottom:8px">Catway</h3>
        <p><code>catwayNumber</code> : Number, unique, requis</p>
        <p><code>catwayType</code> : String, "long" ou "short", requis</p>
        <p><code>catwayState</code> : String, description de l'état, requis</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:8px">Réservation</h3>
        <p><code>catwayNumber</code> : Number, requis</p>
        <p><code>clientName</code> : String, requis</p>
        <p><code>boatName</code> : String, requis</p>
        <p><code>startDate</code> : Date, requis</p>
        <p><code>endDate</code> : Date, requis</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:8px">Utilisateur</h3>
        <p><code>username</code> : String, requis</p>
        <p><code>email</code> : String, unique, requis</p>
        <p><code>password</code> : String, hashé, min. 6 caractères</p>
      </div>
    </section>
  </div>
</body>
</html>
