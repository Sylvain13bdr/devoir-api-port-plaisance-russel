<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Catway <%= catway.catwayNumber %> - Port Russell</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <span class="brand">Port de Plaisance Russell</span>
    <div>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/reservations">Réservations</a>
      <a href="/users">Utilisateurs</a>
      <a href="/api-docs">Documentation API</a>
      <a href="/logout">Déconnexion</a>
    </div>
  </nav>
  <div class="container">
    <h1>Catway n° <%= catway.catwayNumber %></h1>
    <div class="card">
      <p><strong>Numéro :</strong> <%= catway.catwayNumber %></p>
      <p><strong>Type :</strong> <%= catway.catwayType %></p>
      <p><strong>État :</strong> <%= catway.catwayState %></p>
    </div>
    <a href="/catways/<%= catway.catwayNumber %>/reservations" class="btn btn-primary">Voir les réservations</a>
    <a href="/catways/<%= catway.catwayNumber %>/edit" class="btn btn-secondary">Modifier</a>
    <a href="/catways" class="btn btn-secondary">Retour</a>
  </div>
</body>
</html>
